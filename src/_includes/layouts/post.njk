---
layout: layouts/base.njk
extraCss:
  - /assets/css/blog.css
---
<div class="container page-body">
  <article>
    <header class="post-header">
      <h1 class="post-title">{{ title }}</h1>
      <div class="post-meta">
        <time datetime="{{ page.date | isoDate }}">{{ page.date | dateDisplay }}</time>
        {% if tags %}
          <span class="tags">
            {% for tag in tags %}
              <a href="/blog/?tag={{ tag }}" class="tag">{{ tag }}</a>
            {% endfor %}
          </span>
        {% endif %}
      </div>
    </header>

    <div class="post-layout">
      <div class="post-main">
        <div class="post-body">
          {{ content | safe }}
        </div>

        {% if references %}
        <section class="post-references" aria-label="References">
          <h2 class="ref-heading">References</h2>
          <ol class="ref-list">
            {% for ref in references %}
            <li class="ref-item" id="ref-{{ loop.index }}">
              <span class="ref-authors">{{ ref.authors }}</span>.
              {% if ref.url %}
                <a href="{{ ref.url }}" class="ref-title" target="_blank" rel="noopener">{{ ref.title }}</a>.
              {% else %}
                <span class="ref-title">{{ ref.title }}</span>.
              {% endif %}
              {% if ref.venue %}<em class="ref-venue">{{ ref.venue }}</em>{% if ref.year %},{% endif %}{% endif %}
              {% if ref.year %} {{ ref.year }}{% endif %}.
            </li>
            {% endfor %}
          </ol>
        </section>
        {% endif %}

        <footer class="post-footer">
          <a href="/blog/" class="post-nav-link">← all posts</a>
        </footer>
      </div>

      {% if sidenotes %}
      <aside class="post-sidenotes" aria-label="Sidenotes">
        {% for note in sidenotes %}
          <div class="sidenote">
            <span class="sidenote-label">{{ note.label or ("note " + loop.index) }}</span>
            {{ note.text }}
          </div>
        {% endfor %}
      </aside>
      {% endif %}
    </div>
  </article>
</div>
